  "allOf": [
    {
      "$comment": "If openMetricsPortOutsideKubernetes is true, exportMetrics must also be true",
      "if": {
        "required": [
          "openMetricsPortOutsideKubernetes"
        ],
        "properties": {
          "openMetricsPortOutsideKubernetes": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "exportMetrics"
        ],
        "properties": {
          "exportMetrics": {
            "const": true
          }
        }
      }
    },
    {
      "$comment": "If internalClientsOnly is true, openMetricsPortOutsideKubernetes must be false",
      "if": {
        "required": [
          "internalClientsOnly"
        ],
        "properties": {
          "internalClientsOnly": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "openMetricsPortOutsideKubernetes"
        ],
        "properties": {
          "openMetricsPortOutsideKubernetes": {
            "const": false
          }
        }
      }
    }
